# =============================================================================
# TODO Microservice Application - Docker Environment Configuration (Example)
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
APP_ENV=docker
DEBUG=true
LOG_LEVEL=INFO

# ── Todo Service ─────────────────────────────────────────────────────────────
TODO_SERVICE_HOST=0.0.0.0
TODO_SERVICE_PORT=8001
TODO_SERVICE_PREFIX=/api/v1/todos

# ── Attachment Service ───────────────────────────────────────────────────────
ATTACHMENT_SERVICE_HOST=0.0.0.0
ATTACHMENT_SERVICE_PORT=8002
ATTACHMENT_SERVICE_PREFIX=/api/v1/attachments

# ── Notification Service ─────────────────────────────────────────────────────
NOTIFICATION_SERVICE_HOST=0.0.0.0
NOTIFICATION_SERVICE_PORT=8003
NOTIFICATION_SERVICE_PREFIX=/api/v1/notifications

# ── AWS / LocalStack ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# ── DynamoDB Configuration ───────────────────────────────────────────────────
DYNAMODB_TODOS_TABLE=todos
DYNAMODB_ATTACHMENTS_TABLE=attachments
DYNAMODB_NOTIFICATIONS_TABLE=notifications

# ── S3 Configuration ────────────────────────────────────────────────────────
S3_BUCKET_NAME=todo-attachments
S3_PRESIGNED_URL_EXPIRY=3600

# ── SES Configuration ───────────────────────────────────────────────────────
SES_SENDER_EMAIL=your-email@example.com
SES_VERIFIED_EMAIL=your-email@example.com

# ── Inter-Service Communication ──────────────────────────────────────────────
TODO_SERVICE_URL=http://todo-service:8001
ATTACHMENT_SERVICE_URL=http://attachment-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8003

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://frontend:3000"]
